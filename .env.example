# ProofStack — Environment Configuration
# Copy to .env and fill in values

# Required: GitHub personal access token (classic or fine-grained)
GITHUB_TOKEN=ghp_your_personal_access_token_here

# PostgreSQL connection string (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost/proofstack

# API authentication key — change in production
API_KEY=proofstack-demo-2025

# Redis connection string (Celery broker + cache)
REDIS_URL=redis://localhost:6379/0

# Frontend origin for CORS
FRONTEND_URL=http://localhost:3000
